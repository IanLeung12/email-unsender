{
  "manifest_version": 3,
  "name": "Email Unsender",
  "version": "0.1.0",
  "description": "A second line of defense for Gmail and Outlook. Unsend emails within a configurable time window or recall already-sent emails.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "*://mail.google.com/*",
    "*://gmail.google.com/*",
    "*://outlook.office.com/*",
    "*://outlook.live.com/*"
  ],
  "background": {
    "scripts": ["background/background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "*://mail.google.com/*",
        "*://gmail.google.com/*"
      ],
      "js": [
        "content/gmail.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://outlook.office.com/*",
        "*://outlook.live.com/*"
      ],
      "js": [
        "content/outlook.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Email Unsender",
    "default_popup": "popup/popup.html",
    "default_icons": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "options_page": "options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["pages/oauth-callback.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
